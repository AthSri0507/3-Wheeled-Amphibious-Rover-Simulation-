<mujoco model="amphibious_rover">
  <!-- ============================================================
       Amphibious Triangular Rover - ported from rover_terrain.wbt
       Z-up, metres. Detailed STL meshes for visuals, primitive
       geoms for collision (mirrors the Webots boundingObjects).
       Buoyancy / propeller thrust are applied in rover_sim.py.
       ============================================================ -->

  <compiler meshdir=".." angle="radian" autolimits="true"/>
  <option timestep="0.004" integrator="implicitfast" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <quality shadowsize="4096"/>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.35 0.35 0.35" specular="0 0 0"/>
  </visual>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" mass="0"/>
    </default>
    <!-- rover collision geoms: contype=2/conaffinity=1 so they collide with the
         ground/rocks (1/2) but NOT with each other (no rover self-collision). -->
    <default class="collision">
      <geom group="3" rgba="0.5 0.5 0.5 0.25" condim="3" contype="2" conaffinity="1"/>
    </default>
    <default class="wheel">
      <!-- coulombFriction 1.5, bounce ~0.01 -> tangential/torsional/rolling friction -->
      <geom type="cylinder" group="3" rgba="0.5 0.5 0.5 0.25" contype="2" conaffinity="1"
            friction="1.5 0.01 0.0001" condim="6" solref="0.01 1" solimp="0.9 0.95 0.001"/>
    </default>
    <!-- position-servo defaults -->
    <default class="tilt">
      <position kp="12" kv="0.5"/>
    </default>
    <default class="spin">
      <velocity kv="0.4"/>
    </default>
  </default>

  <asset>
    <!-- bright sky-blue skybox (no dark band) so the background never reads as black -->
    <texture name="sky" type="skybox" builtin="gradient" rgb1="0.55 0.72 0.92" rgb2="0.35 0.46 0.60"
             width="512" height="512"/>
    <!-- flat natural sand ground (solid colour, no tile/grout lines) -->
    <material name="ground" rgba="0.76 0.66 0.48 1" reflectance="0.0"/>
    <material name="water" rgba="0.18 0.42 0.75 0.35" reflectance="0.05"/>

    <!-- beach terrain: flat land that ramps down into a deep water basin (-Y side).
         size = radius_x radius_y elevation base; with the geom at z=-0.5, normalised
         height 1.0 -> top z=0 (land), 0.2 -> top z=-0.4 (basin). See make_terrain.py. -->
    <hfield name="terrain" file="beach.png" size="4 4 0.5 0.3"/>

    <!-- ===== meshes (mm, scaled to metres) ===== -->
    <mesh name="chassis" file="chassis.STL" scale="0.001 0.001 0.001"/>

    <!-- front (right-side) wheel assembly meshes; left arm reuses these -->
    <mesh name="arm"          file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 arm_1.step-1.STL"          scale="0.001 0.001 0.001"/>
    <mesh name="arm_ball"     file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 arm_ball_stud_1.step-1.STL" scale="0.001 0.001 0.001"/>
    <mesh name="pivot_bracket" file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 pivot_bracket_1.step-1.STL" scale="0.001 0.001 0.001"/>
    <mesh name="pivot_pin"    file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 pivot_pin_1.step-1.STL"     scale="0.001 0.001 0.001"/>
    <mesh name="axle"         file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 axle_1.step-1.STL"         scale="0.001 0.001 0.001"/>
    <mesh name="coupler"      file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 coupler_1.step-1.STL"      scale="0.001 0.001 0.001"/>
    <mesh name="motor"        file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 motor_1.step-1.STL"        scale="0.001 0.001 0.001"/>
    <mesh name="motor_enc"    file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 motor_enc.step-1.STL"      scale="0.001 0.001 0.001"/>
    <mesh name="wheel"        file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 wheel_1.step-1.STL"        scale="0.001 0.001 0.001"/>
    <mesh name="tire"         file="front_right_wheel_assembly - front_right_wheel_assembly.step-1 tire_1.step-1.STL"         scale="0.001 0.001 0.001"/>

    <!-- rear swivel assembly meshes -->
    <mesh name="rear_module"    file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_module_2.step-1.STL"    scale="0.001 0.001 0.001"/>
    <mesh name="rear_motor"     file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_motor_2.step-1.STL"     scale="0.001 0.001 0.001"/>
    <mesh name="rear_motor_enc" file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_motor_enclosure.step-1.STL" scale="0.001 0.001 0.001"/>
    <mesh name="rear_axle"      file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_axle_2.step-1.STL"      scale="0.001 0.001 0.001"/>
    <mesh name="rear_kingpin"   file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_kingpin_2.step-1.STL"   scale="0.001 0.001 0.001"/>
    <mesh name="rear_coupler"   file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_coupler_2.step-1.STL"   scale="0.001 0.001 0.001"/>
    <mesh name="rear_link"      file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_link_2.step-1.STL"      scale="0.001 0.001 0.001"/>
    <mesh name="rear_ball"      file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_ball_stud_2.step-1.STL" scale="0.001 0.001 0.001"/>
    <mesh name="rear_wheel"     file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_wheel_2.step-1.STL"     scale="0.001 0.001 0.001"/>
    <mesh name="rear_tire"      file="rear_complete_swivel_assembly - rear_complete_swivel_assembly.step-1 rear_tire_2.step-1.STL"      scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="1.5 -1.5 2.5" dir="-0.5 0.5 -1" diffuse="0.4 0.4 0.4"/>

    <!-- beach terrain (land ramps down into the water basin toward -Y) -->
    <geom name="terrain" type="hfield" hfield="terrain" pos="0 0 -0.5" material="ground"
          condim="3" friction="1.0 0.01 0.0001" contype="1" conaffinity="2"/>

    <!-- water surface (visual only): thin slab covering the basin/beach (y < -0.55).
         Top face is at z~=0 = WATER_Z in rover_sim.py; xy bounds mirror WATER_REGION. -->
    <geom name="water" type="box" pos="0 -2.3 -0.005" size="4 1.75 0.004"
          material="water" contype="0" conaffinity="0" group="1"/>

    <!-- a few "rocks" on the land side (y > 0) -->
    <geom name="rock1" type="sphere" pos="-0.9 0.7 0.03" size="0.05" rgba="0.4 0.38 0.35 1" contype="1" conaffinity="2"/>
    <geom name="rock2" type="box"    pos="0.6 0.9 0.025" size="0.04 0.05 0.025" rgba="0.45 0.42 0.38 1" contype="1" conaffinity="2"/>
    <geom name="rock3" type="sphere" pos="0.5 0.4 0.025" size="0.035" rgba="0.4 0.38 0.35 1" contype="1" conaffinity="2"/>

    <!-- ===================== ROVER ===================== -->
    <body name="rover" pos="0 0 0.125">
      <freejoint name="root"/>
      <inertial pos="0 -0.025 -0.045" mass="0.55" diaginertia="2.20e-03 2.20e-03 3.80e-03"/>
      <site name="imu" pos="0 0 0" size="0.005"/>
      <camera name="chase" pos="0 -0.6 0.35" xyaxes="1 0 0 0 0.5 1" mode="trackcom"/>

      <!-- chassis visual -->
      <geom class="visual" mesh="chassis" pos="-0.083 -0.06596 -0.0175" rgba="0.15 0.65 0.55 1"/>
      <!-- electronics box (visual) -->
      <geom class="visual" type="box" pos="0 0 0.024" size="0.035 0.04 0.0125" rgba="0.08 0.08 0.1 1"/>
      <!-- camera box (visual) -->
      <geom class="visual" type="box" pos="0 0.018 0.032" size="0.006 0.006 0.006" rgba="0.1 0.2 0.85 1"/>
      <!-- body collision -->
      <geom name="body_col" class="collision" type="box" size="0.080 0.065 0.014"/>

      <!-- ===== FRONT-RIGHT ARM + WHEEL ===== -->
      <body name="front_right_arm" pos="0.060 0.035 -0.005">
        <joint name="front_right_tilt" type="hinge" axis="0 1 0" pos="0 -0.005 -0.005"
               range="-1.5708 0.05" damping="0.05"/>
        <inertial pos="0 0 -0.03" mass="0.12" diaginertia="4.0e-5 6.85e-5 3.65e-5"/>
        <geom class="visual" mesh="arm"           pos="-0.05550 -0.03291 -0.05481" rgba="0.15 0.65 0.55 1"/>
        <geom class="visual" mesh="arm_ball"      pos="-0.03300 -0.03941 -0.06381" rgba="0.7 0.7 0.72 1"/>
        <geom class="visual" mesh="pivot_bracket" pos="-0.05950 -0.03291 -0.08431" rgba="0.25 0.25 0.28 1"/>
        <geom class="visual" mesh="pivot_pin"     pos="-0.05700 -0.03266 -0.08181" rgba="0.6 0.6 0.65 1"/>
        <geom class="visual" mesh="axle"          pos="-0.05700 -0.03291 -0.03181" rgba="0.65 0.65 0.7 1"/>
        <geom class="visual" mesh="coupler"       pos="-0.08550 -0.03291 -0.03181" rgba="0.55 0.55 0.6 1"/>
        <geom class="visual" mesh="motor"         pos="-0.11750 -0.03291 -0.03181" rgba="0.3 0.3 0.35 1"/>
        <geom class="visual" mesh="motor_enc"     pos="-0.12250 -0.03041 -0.03181" rgba="0.2 0.2 0.25 1"/>
        <geom name="fr_arm_col" class="collision" type="box" size="0.0285 0.010 0.030" pos="0 0 -0.03"/>

        <body name="front_right_wheel" pos="0 0 -0.058">
          <joint name="front_right_wheel" type="hinge" axis="1 0 0" pos="0 0 0" armature="0.002" damping="0.002"/>
          <inertial pos="0 0 0" mass="0.04982" diaginertia="4.104e-05 2.218e-05 2.218e-05"/>
          <geom class="visual" mesh="wheel" pos="-0.06100 -0.03291 -0.03181" rgba="0.22 0.22 0.25 1"/>
          <geom class="visual" mesh="tire"  pos="-0.05700 -0.03291 -0.03181" rgba="0.07 0.07 0.07 1"/>
          <geom name="fr_wheel_col" class="wheel" size="0.031 0.010" axisangle="0 1 0 1.5708"/>
        </body>
      </body>

      <!-- ===== FRONT-LEFT ARM + WHEEL (mirror, body yawed 180 deg) ===== -->
      <body name="front_left_arm" pos="-0.060 0.030 -0.010" axisangle="0 0 1 3.14159265">
        <!-- axis is 0 -1 0 (not 0 1 0): this body is yawed 180 deg, so the joint axis
             lives in the rotated frame. -Y here = world +Y, making the left arm splay
             OUTWARD to the left (symmetric with the right arm) in water mode. -->
        <joint name="front_left_tilt" type="hinge" axis="0 -1 0" pos="0 0 0"
               range="-0.05 1.5708" damping="0.05"/>
        <inertial pos="0 0 -0.03" mass="0.12" diaginertia="4.0e-5 6.85e-5 3.65e-5"/>
        <geom class="visual" mesh="arm"           pos="-0.05550 -0.03291 -0.05481" rgba="0.15 0.65 0.55 1"/>
        <geom class="visual" mesh="arm_ball"      pos="-0.03300 -0.03941 -0.06381" rgba="0.7 0.7 0.72 1"/>
        <geom class="visual" mesh="pivot_bracket" pos="-0.05950 -0.03291 -0.08431" rgba="0.25 0.25 0.28 1"/>
        <geom class="visual" mesh="pivot_pin"     pos="-0.05700 -0.03266 -0.08181" rgba="0.6 0.6 0.65 1"/>
        <geom class="visual" mesh="axle"          pos="-0.05700 -0.03291 -0.03181" rgba="0.65 0.65 0.7 1"/>
        <geom class="visual" mesh="coupler"       pos="-0.08550 -0.03291 -0.03181" rgba="0.55 0.55 0.6 1"/>
        <geom class="visual" mesh="motor"         pos="-0.11750 -0.03291 -0.03181" rgba="0.3 0.3 0.35 1"/>
        <geom class="visual" mesh="motor_enc"     pos="-0.12250 -0.03041 -0.03181" rgba="0.2 0.2 0.25 1"/>
        <geom name="fl_arm_col" class="collision" type="box" size="0.0285 0.010 0.030" pos="0 0 -0.03"/>

        <body name="front_left_wheel" pos="0 0 -0.058">
          <joint name="front_left_wheel" type="hinge" axis="-1 0 0" pos="0 0 0" armature="0.002" damping="0.002"/>
          <inertial pos="0 0 0" mass="0.04982" diaginertia="4.104e-05 2.218e-05 2.218e-05"/>
          <geom class="visual" mesh="wheel" pos="-0.06100 -0.03291 -0.03181" rgba="0.22 0.22 0.25 1"/>
          <geom class="visual" mesh="tire"  pos="-0.05700 -0.03291 -0.03181" rgba="0.07 0.07 0.07 1"/>
          <geom name="fl_wheel_col" class="wheel" size="0.031 0.010" axisangle="0 1 0 1.5708"/>
        </body>
      </body>

      <!-- ===== REAR POD + SWIVEL ===== -->
      <body name="rear_pod" pos="0 -0.069 -0.010">
        <joint name="rear_swivel" type="hinge" axis="0 0 1" pos="0 0 0"
               range="-1.5708 1.5708" stiffness="5.0" damping="2.0"/>
        <inertial pos="0 0 -0.02" mass="0.20" diaginertia="1.77e-4 2.417e-4 2.054e-4"/>
        <geom class="visual" mesh="rear_module"    pos="-0.02525 -0.03671 -0.05506" rgba="0.15 0.65 0.55 1"/>
        <geom class="visual" mesh="rear_motor"     pos="-0.08575 -0.03171 -0.03181" rgba="0.3 0.3 0.35 1"/>
        <geom class="visual" mesh="rear_motor_enc" pos="-0.09075 -0.02921 -0.03181" rgba="0.2 0.2 0.25 1"/>
        <geom class="visual" mesh="rear_axle"      pos="-0.02525 -0.03171 -0.03181" rgba="0.65 0.65 0.7 1"/>
        <geom class="visual" mesh="rear_kingpin"   pos="-0.02525 -0.03171 -0.08181" rgba="0.5 0.5 0.55 1"/>
        <geom class="visual" mesh="rear_coupler"   pos="-0.05375 -0.03171 -0.03181" rgba="0.55 0.55 0.6 1"/>
        <geom class="visual" mesh="rear_link"      pos="-0.02525 -0.06371 -0.07491" rgba="0.4 0.4 0.45 1"/>
        <geom class="visual" mesh="rear_ball"      pos="-0.02525 -0.05621 -0.07381" rgba="0.7 0.7 0.72 1"/>
        <geom name="rear_pod_col" class="collision" type="box" size="0.045 0.0325 0.040" pos="0 0 -0.02"/>

        <body name="rear_prop_mount" pos="0 0 -0.040">
          <joint name="rear_prop_tilt" type="hinge" axis="0 0 1" pos="0 0 0"
                 range="0 1.5708" damping="0.05"/>
          <inertial pos="0 0 0" mass="0.010" diaginertia="1.87e-6 1.87e-6 8.07e-7"/>
          <geom name="prop_mount_col" class="collision" type="box" size="0.011 0.011 0.021"/>

          <body name="rear_prop_wheel" pos="0 0 -0.020">
            <joint name="rear_wheel" type="hinge" axis="1 0 0" pos="0 0 0.002" armature="0.002" damping="0.002"/>
            <inertial pos="0 0 0" mass="0.04582" diaginertia="2.040e-05 3.774e-05 2.040e-05"/>
            <geom class="visual" mesh="rear_wheel" pos="-0.02925 -0.03171 -0.03181" rgba="0.22 0.22 0.25 1"/>
            <geom class="visual" mesh="rear_tire"  pos="-0.02525 -0.03171 -0.03181" rgba="0.07 0.07 0.07 1"/>
            <geom name="rear_wheel_col" class="wheel" size="0.031 0.010" axisangle="0 1 0 1.5708"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- ===================== ACTUATORS ===================== -->
  <actuator>
    <!-- drive wheels: velocity servo (target rad/s) -->
    <velocity name="front_left_wheel"  class="spin" joint="front_left_wheel"  ctrlrange="-10.472 10.472" forcerange="-0.8 0.8"/>
    <velocity name="front_right_wheel" class="spin" joint="front_right_wheel" ctrlrange="-10.472 10.472" forcerange="-0.8 0.8"/>
    <velocity name="rear_wheel"        class="spin" joint="rear_wheel"        ctrlrange="-10.472 10.472" forcerange="-1.5 1.5"/>

    <!-- arm tilt / swivel / prop tilt: position servo (target rad) -->
    <position name="front_right_tilt" class="tilt" joint="front_right_tilt" ctrlrange="-1.5708 0.05"   forcerange="-2 2"/>
    <position name="front_left_tilt"  class="tilt" joint="front_left_tilt"  ctrlrange="-0.05 1.5708"   forcerange="-2 2"/>
    <position name="rear_swivel"      class="tilt" joint="rear_swivel"      ctrlrange="-1.5708 1.5708" forcerange="-5 5" kp="20"/>
    <position name="rear_prop_tilt"   class="tilt" joint="rear_prop_tilt"   ctrlrange="0 1.5708"       forcerange="-2 2"/>
  </actuator>

  <!-- ===================== SENSORS ===================== -->
  <sensor>
    <framequat   name="imu_quat"  objtype="site" objname="imu"/>
    <gyro        name="imu_gyro"  site="imu"/>
    <accelerometer name="imu_acc" site="imu"/>
    <jointpos name="fr_tilt_pos"   joint="front_right_tilt"/>
    <jointpos name="fl_tilt_pos"   joint="front_left_tilt"/>
    <jointpos name="swivel_pos"    joint="rear_swivel"/>
    <jointpos name="prop_tilt_pos" joint="rear_prop_tilt"/>
    <jointvel name="fl_wheel_vel"  joint="front_left_wheel"/>
    <jointvel name="fr_wheel_vel"  joint="front_right_wheel"/>
    <jointvel name="rear_wheel_vel" joint="rear_wheel"/>
  </sensor>
</mujoco>
